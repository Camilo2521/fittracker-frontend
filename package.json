{
  "name": "fit-tracker",
  "version": "1.0.1",
  "description": "App completa de fitness y nutrición para cualquier persona que quiera alcanzar su mejor versión física",
  "scripts": {
    "build": "node scripts/build.js",
    "build:android": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "dev": "npx cap sync"
  },
  "dependencies": {
    "@capacitor/android": "6.2.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "6.2.0",
    "@capacitor/splash-screen": "6.0.2",
    "@capacitor/status-bar": "6.0.2",
    "@mediapipe/tasks-vision": "^0.10.0",
    "@tensorflow/tfjs": "^4.15.0",
    "@tensorflow/tfjs-backend-webgl": "^4.15.0",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow-models/body-segmentation": "^1.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "6.2.0",
    "terser": "^5.24.0"
  }
}
